# Application Settings
APP_NAME="M-Kopa AOIS API"
APP_VERSION="1.0.0"
DEBUG=True
ENVIRONMENT=development

# API Settings
API_V1_PREFIX=/api/v1
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
# For psycopg (psycopg3 - recommended for Windows)
DATABASE_URL=postgresql://mkopa_user:mkopa_password@localhost:5432/mkopa_aois
# Or for asyncpg (async operations)
# DATABASE_URL=postgresql+asyncpg://mkopa_user:mkopa_password@localhost:5432/mkopa_aois
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis Cache
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# CORS Settings
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# External Services
GOOGLE_FORMS_WEBHOOK_SECRET=your-webhook-secret
MICROSOFT_FORMS_WEBHOOK_SECRET=your-webhook-secret

# Storage
FILE_STORAGE_PATH=./storage
REPORTS_STORAGE_PATH=./storage/reports

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@mkopa-aois.com
EMAILS_FROM_NAME="M-Kopa AOIS"
